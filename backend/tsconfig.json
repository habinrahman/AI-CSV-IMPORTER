{
  "extends": "../tsconfig.base.json",
  "compilerOptions": {
    "composite": true,
    "module": "CommonJS",
    "moduleResolution": "Node",
    "rootDir": "./src",
    "outDir": "./dist",
    "tsBuildInfoFile": "./dist/.tsbuildinfo",
    "types": ["node"]
  },
  "references": [{ "path": "../shared" }],
  "include": ["src/**/*"],
  // Tests run through Vitest's own transform and must not land in dist.
  "exclude": ["src/**/*.test.ts"]
}
