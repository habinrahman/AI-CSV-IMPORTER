# ============================================================
# Root reference for all environment variables.
# Copy the relevant sections into:
#   backend/.env         (see backend/.env.example)
#   frontend/.env.local  (see frontend/.env.example)
# ============================================================

# ─── Backend ────────────────────────────────────────────────
NODE_ENV=development
PORT=4000
CORS_ORIGIN=http://localhost:3000
LOG_LEVEL=info

# Rate limiting (per IP)
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100

# Persistence — Supabase Postgres via Drizzle (optional; in-memory without it).
# Use the transaction-pooler URL (port 6543); apply schema: npm run db:push --workspace backend
# DATABASE_URL=postgresql://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres

# Uploads — temporary working files, swept after the TTL
MAX_FILE_SIZE_MB=5
# UPLOAD_DIR=            # defaults to <os tmpdir>/groweasy-uploads
UPLOAD_TTL_MINUTES=30
JOB_TTL_MINUTES=60

# AI pipeline (the key matching AI_PROVIDER is required to run imports)
AI_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
AI_TIMEOUT_MS=60000
AI_CONCURRENCY=2
BATCH_SIZE=20
MAX_CONCURRENT_JOBS=4
MAX_RETRIES=3
PROMPT_VERSION=v2
DEFAULT_PHONE_REGION=IN

# ─── Frontend ───────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:4000
